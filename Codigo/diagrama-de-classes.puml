@startuml

' INTERFACE
interface Autenticavel {
  + login(usuario: String, senha: String): Boolean
  + logout(): void
  + trocarSenha(senhaAntiga: String, senhaNova: String): Boolean
}

' CLASSES ABSTRATAS
abstract class Usuario {
  - id: Integer
  - nome: String
  - email: String
  - senha: String
  - dataCadastro: Date
  + {abstract} getPermissoes(): List
  + atualizarDados(): void
}

' HERANÇA 
Usuario <|-- Atleta
Usuario <|-- Operador
Autenticavel <|.. Usuario

'  CLASSE ATLETA
class Atleta {
  - pais: String
  - dataNascimento: Date
  - modalidades: List
  + inscreverEmCompeticao(competicao: Competicao): Boolean
  + consultarInscricoes(): List
  + getPermissoes(): List
  + verificarPaisPorModalidade(modalidade: String): Boolean
}

' CLASSE OPERADOR
class Operador {
  - cargo: String
  - nivelAcesso: Integer
  + cadastrarCompeticao(competicao: Competicao): void
  + alocarLocal(competicao: Competicao, local: Local): Boolean
  + registrarResultados(resultado: Resultado): void
  + gerarRelatorioMedalhas(): Relatorio
  + getPermissoes(): List
}

' CLASSES DE DOMÍNIO
class Competicao {
  - id: Integer
  - nomeModalidade: String
  - data: Date
  - horario: String
  - status: StatusCompeticao
  + adicionarAtleta(atleta: Atleta): Boolean
  + removerAtleta(atleta: Atleta): Boolean
  + definirResultado(ouro: Atleta, prata: Atleta, bronze: Atleta): void
  + getAtletasInscritos(): List
  + getLocalAlocado(): Local
  + setLocal(local: Local): void
}

class Local {
  - id: Integer
  - nome: String
  - endereco: String
  - capacidade: Integer
  + verificarDisponibilidade(data: Date, horario: String): Boolean
  + alocar(competicao: Competicao): Boolean
  + getCompeticaoAlocada(data: Date, horario: String): Competicao
}

class Resultado {
  - id: Integer
  - dataRegistro: Date
  - atletaOuro: Atleta
  - atletaPrata: Atleta
  - atletaBronze: Atleta
  + validarPódio(): Boolean
  + getMedalhaPorAtleta(atleta: Atleta): String
}

class Pais {
  - codigo: String
  - nome: String
  - continente: String
  - medalhasOuro: Integer
  - medalhasPrata: Integer
  - medalhasBronze: Integer
  + getTotalMedalhas(): Integer
  + getQuadroMedalhas(): String
  + adicionarMedalha(tipo: String): void
}

class Inscricao {
  - id: Integer
  - dataInscricao: Date
  - status: StatusInscricao
  - paisRepresentado: String
  + cancelar(): void
  + confirmar(): void
  + validarUnicoPaisPorModalidade(): Boolean
}

class Relatorio {
  - id: Integer
  - dataGeracao: Date
  - tipo: String
  - conteudo: String
  + exportarPDF(): String
  + exportarCSV(): String
  + gerarQuadroMedalhas(paises: List): String
}

' ENUMS 
enum StatusCompeticao {
  AGENDADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

enum StatusInscricao {
  PENDENTE
  CONFIRMADA
  CANCELADA
}

' RELACIONAMENTOS

' Associação de enums
Competicao --> StatusCompeticao
Inscricao --> StatusInscricao

' Composição (todo forte) - Resultado pertence a uma única Competicao
Competicao "*" *-- "1" Resultado

' Agregação (todo fraco) - Local pode existir sem Competicao
Competicao "1" o-- "0..1" Local
note right of Local : Um local só pode\nabrigar uma competição\npor horário

' Agregação - Pais pode existir sem Atleta
Pais "1" o-- "0..*" Atleta

' Associações com multiplicidades
Competicao "1" -- "0..*" Inscricao
Atleta "1" -- "0..*" Inscricao

' Restrição: Atleta só pode representar um país por modalidade
note left of Inscricao : Um atleta só pode\nrepresentar um país\nem cada modalidade

' Associações simples de navegação
Operador --> Resultado : registra
Operador --> Relatorio : gera
Atleta --> Resultado : consulta

' Associação Competicao-Atleta (lista de participantes)
Competicao "1" -- "0..*" Atleta : participantes

' Relacionamento Resultado com Atletas (medalhistas)
Resultado --> Atleta : ouro
Resultado --> Atleta : prata
Resultado --> Atleta : bronze

' País tem relação com medalhas via Resultado
Pais --> Resultado : possui medalhas

@enduml
